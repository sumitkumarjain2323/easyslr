    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2",
    "vite-tsconfig-paths": "^6.1.1",
